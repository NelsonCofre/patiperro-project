# Copiar a .env.local (misma carpeta que este archivo) y ajustar la URL cuando cambie el túnel del frontend.
# Formato Java .properties: una clave por línea, sin comillas alrededor del valor.
GATEWAY_EXTRA_CORS_ORIGINS=patiperro.mercadopago.checkout.public-front-base-url=https://len-attending-aspects-weight.trycloudflare.com